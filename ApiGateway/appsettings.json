{
    "ReverseProxy": {
        "Routes": {

            "identity-route": {
                "ClusterId": "identity-cluster",
                "Match": {
                    "Path": "/identity/{**catch-all}"
                },
                "Transforms": [ { "PathRemovePrefix": "/identity" } ]

            },

            "hotel-route": {
                "ClusterId": "hotel-cluster",
                "Match": { "Path": "/hotels/{**catch-all}" },
                "Transforms": [ { "PathRemovePrefix": "/hotels" } ]
            },
            "room-route": {
                "ClusterId": "room-cluster",
                "Match": { "Path": "/rooms/{**catch-all}" },
                "Transforms": [ { "PathRemovePrefix": "/rooms" } ]
            },
            "booking-route": {
                "ClusterId": "booking-cluster",
                "Match": { "Path": "/bookings/{**catch-all}" },
                "Transforms": [ { "PathRemovePrefix": "/bookings" } ]
            },
            "payment-route": {
                "ClusterId": "payment-cluster",
                "Match": { "Path": "/payments/{**catch-all}" },
                "Transforms": [ { "PathRemovePrefix": "/payments" } ]
            },
            "identity-swagger": {
                "ClusterId": "identity-cluster",
                "Match": { "Path": "/identity-swagger/{**catch-all}" },
                "Transforms": [ { "PathRemovePrefix": "/identity-swagger" } ]
            },
            "hotel-swagger": {
                "ClusterId": "hotel-cluster",
                "Match": { "Path": "/hotel-swagger/{**catch-all}" },
                "Transforms": [ { "PathRemovePrefix": "/hotel-swagger" } ]
            },
            "room-swagger": {
                "ClusterId": "room-cluster",
                "Match": { "Path": "/room-swagger/{**catch-all}" },
                "Transforms": [ { "PathRemovePrefix": "/room-swagger" } ]
            },
            "booking-swagger": {
                "ClusterId": "booking-cluster",
                "Match": { "Path": "/booking-swagger/{**catch-all}" },
                "Transforms": [ { "PathRemovePrefix": "/booking-swagger" } ]
            },
            "payment-swagger": {
                "ClusterId": "payment-cluster",
                "Match": { "Path": "/payment-swagger/{**catch-all}" },
                "Transforms": [ { "PathRemovePrefix": "/payment-swagger" } ]
            }
        },


        "Clusters": {
            "identity-cluster": {
                "Destinations": {
                    "destination1": { "Address": "http://identityservice:8080/" }
                }
            },
            "hotel-cluster": {
                "Destinations": {
                    "destination1": { "Address": "http://hotelservice:8080/" }
                }
            },
            "room-cluster": {
                "Destinations": {
                    "destination1": { "Address": "http://roomservice:8080/" }
                }
            },
            "booking-cluster": {
                "Destinations": {
                    "destination1": { "Address": "http://bookingservice:8080/" }
                }
            },
            "payment-cluster": {
                "Destinations": {
                    "destination1": { "Address": "http://paymentservice:8080/" }
                }

            }
        }
    }
}
